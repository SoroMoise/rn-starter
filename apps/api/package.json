{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "format": "prettier \"**/*.{ts,json}\" --write",
    "lint": "prettier \"**/*.{ts,json}\" -c"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "hono": "^4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "prettier": "^3.2.5",
    "wrangler": "^4",
    "typescript": "~5.9.2"
  }
}
