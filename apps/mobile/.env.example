# Exchange Rate API Configuration
# Get your API key from https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=YOUR_API_KEY_HERE

# AdMob Configuration
# Get your AdMob IDs from https://admob.google.com/
ADMOB_ANDROID_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX
ADMOB_IOS_APP_ID=ca-app-pub-XXXXXXXXXXXXXXXX~XXXXXXXXXX

# AdMob Banner IDs for specific screens
ADMOB_ANDROID_BANNER_INDEX_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_ANDROID_BANNER_STATISTICS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_ANDROID_BANNER_SETTINGS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_IOS_BANNER_INDEX_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_IOS_BANNER_STATISTICS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_IOS_BANNER_SETTINGS_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# RTL Restart Banner Toggle (true/false)
RTL_RESTART_BANNER_ENABLED=true

# Ad Visibility Toggles (true/false)
AD_BANNER_INDEX_ENABLED=true
AD_BANNER_STATISTICS_ENABLED=true
AD_BANNER_SETTINGS_ENABLED=true
AD_INTERSTITIAL_ENABLED=true
AD_REWARDED_ENABLED=true
AD_REWARDED_FREE_DURATION_MINUTES=60

# Other ads IDs
ADMOB_ANDROID_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_IOS_INTERSTITIAL_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_ANDROID_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX
ADMOB_IOS_REWARDED_ID=ca-app-pub-XXXXXXXXXXXXXXXX/XXXXXXXXXX

# App website (homepage).
APP_WEBSITE_URL=https://all-currency-converter.codeurdivoire.com
# Legal Configuration
LEGAL_PRIVACY_POLICY_URL=https://all-currency-converter.codeurdivoire.com/privacy
LEGAL_TERMS_OF_SERVICE_URL=https://all-currency-converter.codeurdivoire.com/terms
LEGAL_LICENSES_URL=https://all-currency-converter.codeurdivoire.com/licenses
LEGAL_SUPPORT_EMAIL=mailto:support@codeurdivoire.com

# Store URLs
STORE_URL_IOS=https://apps.apple.com/app/id123456789
STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=com.codeurdivoire.allcurencyconverter

# Backend API Configuration
BACKEND_URL=http://localhost:8787
BACKEND_API_KEY=your-backend-api-key

# RevenueCat Configuration
# Get your API keys from https://app.revenuecat.com/
REVENUECAT_IOS_API_KEY=appl_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ANDROID_API_KEY=goog_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
REVENUECAT_ENTITLEMENT_ID="entiitlement_id_here"
REVENUECAT_PRODUCT_ID_MONTHLY=product:product-monthly-id
REVENUECAT_PRODUCT_ID_ANNUAL=product:product-yearly-id

# Subscription grace period: days of premium access after local expiry before hard cut-off
SUBSCRIPTION_GRACE_PERIOD_DAYS=7

# Google Drive Backup
# OAuth 2.0 Web Client ID from Google Cloud Console (same Firebase project)
# Required for Google Sign-In + Drive App Data scope
GOOGLE_WEB_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX.apps.googleusercontent.com
