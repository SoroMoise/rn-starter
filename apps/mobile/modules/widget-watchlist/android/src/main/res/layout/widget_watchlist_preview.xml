<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:orientation="vertical"
  android:background="@color/widget_background"
  android:padding="14dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">
    <TextView
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:text="Watchlist · 14:32"
      android:textColor="@color/widget_muted"
      android:textSize="11sp"
      android:textStyle="bold" />
    <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="PRO"
      android:textColor="@color/widget_pro_badge_text"
      android:background="@color/widget_pro_badge_start"
      android:paddingHorizontal="6dp"
      android:paddingVertical="1dp"
      android:textSize="9sp"
      android:textStyle="bold" />
  </LinearLayout>

  <View
    android:layout_width="match_parent"
    android:layout_height="6dp" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">
    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EUR / USD"
        android:textColor="@color/widget_foreground"
        android:textSize="13sp"
        android:textStyle="bold" />
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.0847"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />
    </LinearLayout>
    <TextView
      android:layout_width="60dp"
      android:layout_height="wrap_content"
      android:text="+0.42%"
      android:textColor="@color/widget_up"
      android:textSize="12sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">
    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="USD / JPY"
        android:textColor="@color/widget_foreground"
        android:textSize="13sp"
        android:textStyle="bold" />
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="154.21"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />
    </LinearLayout>
    <TextView
      android:layout_width="60dp"
      android:layout_height="wrap_content"
      android:text="−0.18%"
      android:textColor="@color/widget_down"
      android:textSize="12sp"
      android:textStyle="bold" />
  </LinearLayout>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="4dp">
    <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:layout_weight="1"
      android:orientation="vertical">
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GBP / EUR"
        android:textColor="@color/widget_foreground"
        android:textSize="13sp"
        android:textStyle="bold" />
      <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="1.1734"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />
    </LinearLayout>
    <TextView
      android:layout_width="60dp"
      android:layout_height="wrap_content"
      android:text="+0.05%"
      android:textColor="@color/widget_up"
      android:textSize="12sp"
      android:textStyle="bold" />
  </LinearLayout>
</LinearLayout>
